# whatsapp-worker — variáveis de ambiente
# Copiar para .env (gitignored) e preencher os valores reais.
# NUNCA commitar este arquivo com credenciais.

# ─────────────────────────────────────────────────────────────────────────────
# Banco de dados
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL — string de conexão Postgres do Supabase.
# Pooler em transaction mode (port 6543) é o padrão — funciona para read e
# write, com a flag prepare:false já configurada em src/db/client.ts.
# Pegar em: Supabase Dashboard → Project Settings → Database → Connection string.
DATABASE_URL=postgres://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────────────────────────
# Redis (BullMQ + debouncer)
# ─────────────────────────────────────────────────────────────────────────────

# REDIS_URL — usado por BullMQ (queue inbound) e pelo debouncer per-contact.
# Em dev local: redis://localhost:6379.  Em prod (docker compose): redis://redis:6379.
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic (Claude — modelo principal da Angelina)
# ─────────────────────────────────────────────────────────────────────────────

# ANTHROPIC_API_KEY — chave da API do Claude.
# Pegar em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-[…]

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (embeddings text-embedding-3-small + fallback gpt-4o)
# ─────────────────────────────────────────────────────────────────────────────

# OPENAI_API_KEY — chave da API OpenAI.
# Usada para:
#   - Embeddings (RAG L4) — model `text-embedding-3-small`, 1536 dims.
#   - Fallback do LLM principal (gpt-4o) quando Claude falha em sequência.
# Pegar em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-EXAMPLE

# ─────────────────────────────────────────────────────────────────────────────
# Zapster (gateway WhatsApp — não é Meta Cloud API)
# ─────────────────────────────────────────────────────────────────────────────

# ZAPSTER_API_URL — base URL da API Zapster (ex: https://api.zapster.dev).
ZAPSTER_API_URL=https://api.zapster.dev

# ZAPSTER_API_KEY — bearer token para chamadas outbound (POST /wa/messages).
ZAPSTER_API_KEY=zps_[…]

# ZAPSTER_INSTANCE_ID — ID da instância (linha de WhatsApp) no Zapster.
ZAPSTER_INSTANCE_ID=inst_[…]

# ZAPSTER_WEBHOOK_ID — ID do webhook cadastrado no painel Zapster.
# Validado no header `x-webhook-id` (camada 2 de auth — 403).
ZAPSTER_WEBHOOK_ID=whk_[…]

# ZAPSTER_WEBHOOK_TOKEN — token aleatório (≥16 chars) embutido no path do webhook.
# URL final cadastrada no Zapster:
#   https://angelina.espacoangelinos.com.br/webhooks/zapster/<ZAPSTER_WEBHOOK_TOKEN>
# Camada 1 de auth (404 se não bater). Gerar com `openssl rand -hex 24`.
ZAPSTER_WEBHOOK_TOKEN=trocar-por-token-aleatorio-de-pelo-menos-16-chars

# ─────────────────────────────────────────────────────────────────────────────
# HTTP server e logging
# ─────────────────────────────────────────────────────────────────────────────

# Porta do edge handler Fastify. Default: 3001.
LUA_HTTP_PORT=3001

# Nível do logger pino. Em prod: info. Em dev: debug.
# Valores: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Features opcionais
# ─────────────────────────────────────────────────────────────────────────────

# INSIGHTS_TRIGGER_SECRET — secret bearer da rota interna POST
# /internal/insights/run (analista de conversas on-demand, disparado pelo app web).
# OPCIONAL: se ausente, o endpoint on-demand retorna 503, mas o CRON diário do
# analista continua funcionando. Deve casar com INSIGHTS_TRIGGER_SECRET do app web.
# Gerar com `openssl rand -hex 24` (mínimo 16 chars).
INSIGHTS_TRIGGER_SECRET=trocar-por-secret-aleatorio-em-producao
